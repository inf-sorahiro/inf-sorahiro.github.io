---
import { getCollection } from 'astro:content';
import { SITE_AUTHOR, SITE_AVATAR, SOCIAL_LINKS, SITE_START_DATE } from '../consts';
import { getWordCount } from '../utils/readingTime';
import { useTranslations, getLocalePath, type Locale } from '../i18n/utils';
import { hideDraft } from '../utils/i18n-content';
import Calendar from './Calendar.astro';

const locale = Astro.currentLocale as Locale;
const t = useTranslations(locale);
const HIDE_DRAFT = hideDraft();

const rawPosts = await getCollection('blog', ({ data }) => data.lang === locale);
const allPosts = HIDE_DRAFT ? rawPosts.filter((p) => !p.data.draft) : rawPosts;
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const totalPosts = sorted.length;
let totalWords = 0;
const categoryMap = new Map<
  string,
  { count: number; recentPosts: typeof allPosts; displayName: string }
>();
const tagMap = new Map<string, number>();

for (const post of sorted) {
  totalWords += getWordCount(post.body || '');

  const cat = post.data.category;
  if (cat) {
    const rootCat = cat.split('/')[0];
    if (!categoryMap.has(rootCat)) {
      categoryMap.set(rootCat, { count: 0, recentPosts: [], displayName: rootCat });
    }
    const entry = categoryMap.get(rootCat)!;
    entry.count++;
    if (entry.recentPosts.length < 3) {
      entry.recentPosts.push(post);
    }
  }

  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const allCategories = Array.from(categoryMap.entries());
const allTags = Array.from(tagMap.entries()).sort((a, b) => b[1] - a[1]);

const CATEGORY_LIMIT = 5;
const TAG_LIMIT = 15;

const randomPosts = sorted
  .sort(() => Math.random() - 0.5)
  .slice(0, 5);

function slugify(post: (typeof sorted)[0]) {
  return post.id.split('/')[0];
}

// --- Calendar data ---
const postsByDate: Record<string, { title: string; slug: string }[]> = {};
const yearMonths = new Set<string>();
for (const post of sorted) {
  const d = post.data.date;
  const key = `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
  if (!postsByDate[key]) postsByDate[key] = [];
  postsByDate[key].push({ title: post.data.title, slug: post.id.split('/')[0] });
  yearMonths.add(`${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`);
}
const sortedYearMonths = Array.from(yearMonths).sort();
const latestYearMonth = sortedYearMonths[sortedYearMonths.length - 1] || '';

// --- Stats: uptime & last updated ---
const now = new Date();
const siteStartDate = new Date(SITE_START_DATE);
const uptimeDays = Math.floor((now.getTime() - siteStartDate.getTime()) / (1000 * 60 * 60 * 24));
const allSitePosts = await getCollection('blog');
const filteredForStats = HIDE_DRAFT ? allSitePosts.filter((p) => !p.data.draft) : allSitePosts;
const sortedForStats = filteredForStats.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const lastUpdated = sortedForStats.length > 0 ? sortedForStats[0].data.date : now;
const lastUpdatedFormatted = `${lastUpdated.getFullYear()}-${String(lastUpdated.getMonth() + 1).padStart(2, '0')}-${String(lastUpdated.getDate()).padStart(2, '0')}`;
---

<aside class="space-y-6">
  <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-6 text-center">
    <img
      src={SITE_AVATAR}
      alt={SITE_AUTHOR}
      class="w-20 h-20 rounded-full mx-auto mb-3 object-cover ring-2 ring-primary/20"
      width="80"
      height="80"
    />
    <h2 class="font-semibold text-lg">{SITE_AUTHOR}</h2>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{t('site.description')}</p>
    <div class="flex items-center justify-center gap-3 mt-4">
      {SOCIAL_LINKS.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-gray-400 hover:text-primary transition-colors"
          title={link.name}
        >
          {link.icon === 'github' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          )}
          {link.icon === 'rss' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
            </svg>
          )}
        </a>
      ))}
    </div>

    <div class="grid grid-cols-2 gap-3 mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
      <div class="text-center">
        <div class="font-semibold text-sm">{totalPosts}</div>
        <div class="text-xs text-gray-400">{t('sidebar.posts')}</div>
      </div>
      <div class="text-center">
        <div class="font-semibold text-sm">{Math.round(totalWords / 1000)}k</div>
        <div class="text-xs text-gray-400">{t('sidebar.words')}</div>
      </div>
      <div class="text-center">
        <div class="font-semibold text-sm">{uptimeDays} {t('sidebar.days')}</div>
        <div class="text-xs text-gray-400">{t('sidebar.uptime')}</div>
      </div>
      <div class="text-center">
        <div class="font-semibold text-sm">{lastUpdatedFormatted}</div>
        <div class="text-xs text-gray-400">{t('sidebar.lastUpdated')}</div>
      </div>
    </div>
  </div>

  {
    sorted.length > 0 && (
      <Calendar
        postsByDate={postsByDate}
        yearMonths={sortedYearMonths}
        locale={locale}
        latestYearMonth={latestYearMonth}
        getLocalePath={(path: string) => getLocalePath(path, locale)}
      />
    )
  }

  {
    allCategories.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5"
        data-sidebar-section="categories"
      >
        <h2 class="text-sm font-semibold mb-3 text-gray-900 dark:text-gray-100">
          {t('sidebar.categories')}
        </h2>
        <div class="sidebar-expand-list flex flex-wrap gap-2">
          {allCategories.map(([name, info], i) => (
              <a
              href={`${getLocalePath('/categories', locale)}/${name}`}
              class={`text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white dark:hover:bg-primary transition-colors ${
                i >= CATEGORY_LIMIT ? 'hidden sidebar-extra' : ''
              }`}
            >
              {info.displayName}
              <span class="ml-1 opacity-60">({info.count})</span>
            </a>
          ))}
        </div>
        {
          allCategories.length > CATEGORY_LIMIT && (
            <button
              type="button"
              class="sidebar-toggle-btn mt-3 text-xs text-primary hover:underline"
              data-expanded="false"
            >
              {t('sidebar.showAll')} ({allCategories.length})
            </button>
          )
        }
      </div>
    )
  }

  {
    allTags.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5"
        data-sidebar-section="tags"
      >
        <h2 class="text-sm font-semibold mb-3 text-gray-900 dark:text-gray-100">
          {t('sidebar.tags')}
        </h2>
        <div class="sidebar-expand-list flex flex-wrap gap-2">
          {allTags.map(([tag, count], i) => (
            <a
              href={`${getLocalePath('/tags', locale)}/${tag}`}
              class={`text-xs px-3 py-1.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-primary hover:text-white dark:hover:bg-primary transition-colors ${
                i >= TAG_LIMIT ? 'hidden sidebar-extra' : ''
              }`}
            >
              {tag}
              <span class="ml-1 opacity-60">({count})</span>
            </a>
          ))}
        </div>
        {
          allTags.length > TAG_LIMIT && (
            <button
              type="button"
              class="sidebar-toggle-btn mt-3 text-xs text-primary hover:underline"
              data-expanded="false"
            >
              {t('sidebar.showAll')} ({allTags.length})
            </button>
          )
        }
      </div>
    )
  }

  {
    randomPosts.length > 0 && (
      <div class="bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5">
        <h2 class="text-sm font-semibold mb-4 text-gray-900 dark:text-gray-100">
          {t('sidebar.random')}
        </h2>
        <div class="space-y-2">
          {randomPosts.map((post) => (
            <a
              href={`${getLocalePath('/post', locale)}/${slugify(post)}`}
              class="block text-xs text-gray-500 dark:text-gray-400 truncate hover:text-primary transition-colors"
            >
              {post.data.title}
            </a>
          ))}
        </div>
      </div>
    )
  }
</aside>

<script define:vars={{ collapseText: t('sidebar.collapse') }}>
  function initSidebarToggles() {
    document.querySelectorAll('.sidebar-toggle-btn').forEach((btn) => {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = 'true';

      const section = btn.closest('[data-sidebar-section]');
      if (!section) return;
      const list = section.querySelector('.sidebar-expand-list');
      if (!list) return;
      const extraItems = list.querySelectorAll('.sidebar-extra');
      const label = btn.textContent || '';

      btn.addEventListener('click', () => {
        const expanded = btn.dataset.expanded === 'true';
        extraItems.forEach((el) => el.classList.toggle('hidden', expanded));
        btn.dataset.expanded = String(!expanded);
        btn.textContent = expanded ? label : collapseText;
      });
    });
  }

  document.addEventListener('astro:page-load', initSidebarToggles);
  initSidebarToggles();
</script>
