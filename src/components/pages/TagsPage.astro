---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getBlogPosts, type Locale } from '../../utils/i18n-content';
import { useTranslations, getLocalePath, type Locale as I18nLocale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale as I18nLocale);

const allPosts = await getBlogPosts(locale);

const tagMap = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags || []) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}

const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);
---

<BlogLayout title={t('tags.title')}>
  <h1 class="text-2xl font-bold mb-8 flex items-center gap-2">
    <span class="w-1 h-6 bg-primary rounded-full inline-block"></span>
    {t('tags.title')}
  </h1>
  <div class="flex flex-wrap gap-3">
    {tags.map((tag) => (
      <a
        href={`${getLocalePath('/tags', locale)}/${tag.name}`}
        class="card-hover bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-sm px-4 py-2.5 group"
      >
        <span class="font-medium group-hover:text-primary transition-colors">
          {tag.name}
        </span>
        <span class="text-xs text-gray-400 dark:text-gray-500 ml-1.5">
          {tag.count}
        </span>
      </a>
    ))}
  </div>
</BlogLayout>
