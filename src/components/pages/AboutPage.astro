---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE_AUTHOR } from '../../consts';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout title={t('about.title')}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-8">
    <article class="prose max-w-none">
      <h1>{t('about.title')}</h1>
      <p>
        {locale === 'zh-tw' ? `你好，我是 ${SITE_AUTHOR}。這裡是基於 Astro 構建的現代化部落格。` : `Hello, I'm ${SITE_AUTHOR}. This is a modern blog built with Astro.`}
      </p>
      <p>
        {locale === 'zh-tw' ? '這裡會記錄我的學習筆記、技術分享和生活隨筆。希望你能在這裡找到有用的內容。' : 'Here I record my learning notes, tech shares, and life essays. Hope you find something useful here.'}
      </p>
      <h2>{t('about.siteTitle')}</h2>
      <ul>
        <li>Framework: <a href="https://astro.build">Astro</a></li>
        <li>Style: Tailwind CSS</li>
        <li>Deploy: Static Site</li>
      </ul>
      <h2>{t('about.contact')}</h2>
      <p>{locale === 'zh-tw' ? '如有任何問題或建議，歡迎透過以下方式聯繫：' : 'If you have any questions or suggestions, feel free to contact me:'}</p>
      <ul>
        <li><a href="https://github.com/inf-sorahiro">GitHub</a></li>
      </ul>
    </article>
  </div>
</BaseLayout>
