---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostList from '../PostList.astro';
import Pagination from '../Pagination.astro';
import { PAGE_SIZE } from '../../consts';
import { resolveCover } from '../../utils/imageStore';
import { getBlogPosts, type Locale } from '../../utils/i18n-content';
import { useTranslations, type Locale as I18nLocale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  currentPage: number;
}

const { locale, currentPage } = Astro.props;
const t = useTranslations(locale as I18nLocale);

const allPosts = await getBlogPosts(locale);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const totalPages = Math.ceil(sorted.length / PAGE_SIZE);
const start = (currentPage - 1) * PAGE_SIZE;
const paginatedPosts = sorted.slice(start, start + PAGE_SIZE);

const postData = paginatedPosts.map((p) => ({
  ...p,
  slug: p.id.split('/')[0],
  data: {
    ...p.data,
    cover: resolveCover('blog', p.id, p.data.cover),
  },
}));

const baseUrl = `/${locale}/`;
---

<BlogLayout title={`${t('pagination.page')} ${currentPage}`}>
  <h1 class="text-2xl font-bold mb-6 text-gray-900 dark:text-gray-100">
    {t('pagination.page')} {currentPage}
  </h1>
  <PostList posts={postData} />
  <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl={baseUrl} />
</BlogLayout>
