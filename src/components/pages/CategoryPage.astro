---
import BlogLayout from '../../layouts/BlogLayout.astro';
import PostList from '../PostList.astro';
import { resolveCover } from '../../utils/imageStore';
import { getBlogPosts, type Locale } from '../../utils/i18n-content';
import { useTranslations, type Locale as I18nLocale } from '../../i18n/utils';

interface Props {
  locale: Locale;
  category: string;
}

const { locale, category } = Astro.props;
const t = useTranslations(locale as I18nLocale);

const allPosts = await getBlogPosts(locale);

const filtered = allPosts
  .filter((post) => {
    const cat = post.data.category;
    if (!cat) return false;
    return cat === category || cat.startsWith(`${category}/`);
  })
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const postData = filtered.map((p) => ({
  ...p,
  slug: p.id.split('/')[0],
  data: {
    ...p.data,
    cover: resolveCover('blog', p.id, p.data.cover),
  },
}));

const displayName = category.split('/').pop()!;
---

<BlogLayout title={displayName}>
  <h1 class="text-2xl font-bold mb-8 flex items-center gap-2">
    <span class="w-1 h-6 bg-primary rounded-full inline-block"></span>
    {t('nav.categories')}：{displayName}
    <span class="text-base font-normal text-gray-400">
      ({filtered.length} {t('categories.count')})
    </span>
  </h1>
  <PostList posts={postData} />
</BlogLayout>
