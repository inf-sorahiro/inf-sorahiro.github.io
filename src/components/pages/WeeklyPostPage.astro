---
import { getEntry, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { getReadingTime, getWordCount } from '../../utils/readingTime';
import { resolveCover } from '../../utils/imageStore';
import { useTranslations, type Locale } from '../../i18n/utils';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const { slug } = Astro.params;
const post = await getEntry('weekly', `${slug}/${locale}`);

if (!post) {
  return Astro.redirect('/404');
}

const coverSrc = resolveCover('weekly', post.id, post.data.cover);

const { Content, headings } = await render(post);

const body = post.body || '';
const wordCount = getWordCount(body);
const readingTime = getReadingTime(body);

function formatDate(d: Date) {
  return d.toISOString().split('T')[0];
}
---

<PostLayout title={post.data.title} description={post.data.description} headings={headings} cover={post.data.cover}>
  <header class="mb-8">
    <span class="inline-block text-sm font-medium text-primary bg-primary/10 px-3 py-1 rounded-full mb-4">
      {t('weekly.issue')}{post.data.issue}
    </span>
    <h1 class="text-3xl font-bold mb-4">{post.data.title}</h1>
    <div class="flex flex-wrap items-center gap-4 text-sm text-gray-400 dark:text-gray-500">
      <time datetime={formatDate(post.data.date)}>
        {formatDate(post.data.date)}
      </time>
      <span>{wordCount} {t('postCard.words')}</span>
      <span>{readingTime} {t('postCard.minRead')}</span>
    </div>
  </header>
  <Content />
</PostLayout>
