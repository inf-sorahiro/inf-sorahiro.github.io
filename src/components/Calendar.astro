---
interface CalendarPost {
  title: string;
  slug: string;
}

interface Props {
  postsByDate: Record<string, CalendarPost[]>;
  yearMonths: string[];
  locale: string;
  latestYearMonth: string;
  getLocalePath: (path: string) => string;
}

const { postsByDate, yearMonths, locale, latestYearMonth, getLocalePath } = Astro.props;

const weekDays =
  locale.startsWith('zh')
    ? ['日', '一', '二', '三', '四', '五', '六']
    : ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];

const monthNames =
  locale.startsWith('zh')
    ? [
        '1月', '2月', '3月', '4月', '5月', '6月',
        '7月', '8月', '9月', '10月', '11月', '12月',
      ]
    : [
        'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
        'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
      ];

const today = new Date();
const todayKey = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

let initYear = today.getFullYear();
let initMonth = today.getMonth();
if (latestYearMonth) {
  const [y, m] = latestYearMonth.split('-').map(Number);
  initYear = y;
  initMonth = m - 1;
}

function daysInMonth(year: number, month: number) {
  return new Date(year, month + 1, 0).getDate();
}

function firstDayOfMonth(year: number, month: number) {
  return new Date(year, month, 1).getDay();
}

function buildCalendarDays(year: number, month: number) {
  const totalDays = daysInMonth(year, month);
  const firstDay = firstDayOfMonth(year, month);
  const days: { day: number; key: string; hasPost: boolean }[] = [];

  for (let i = 0; i < firstDay; i++) {
    days.push({ day: 0, key: '', hasPost: false });
  }
  for (let d = 1; d <= totalDays; d++) {
    const key = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
    days.push({ day: d, key, hasPost: !!postsByDate[key] });
  }
  return days;
}

const initialDays = buildCalendarDays(initYear, initMonth);
---

<div
  class="calendar-widget bg-white dark:bg-[var(--color-card-dark)] rounded-2xl shadow-sm p-5"
  data-posts={JSON.stringify(postsByDate)}
  data-year-months={JSON.stringify(yearMonths)}
  data-locale={locale}
  data-init-year={initYear}
  data-init-month={initMonth}
  data-today={todayKey}
  data-route-prefix={getLocalePath('/post/')}
>
  <div class="flex items-center justify-between mb-4">
    <button
      type="button"
      class="calendar-prev p-1 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      aria-label="Previous month"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <span class="calendar-month-label text-sm font-semibold text-gray-900 dark:text-gray-100">
      {initYear} {monthNames[initMonth]}
    </span>
    <button
      type="button"
      class="calendar-next p-1 rounded-lg text-gray-400 hover:text-gray-600 dark:hover:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
      aria-label="Next month"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>
  </div>

  <div class="grid grid-cols-7 gap-1 text-center mb-2">
    {weekDays.map((wd) => (
      <div class="text-xs text-gray-400 dark:text-gray-500">{wd}</div>
    ))}
  </div>

  <div class="calendar-days grid grid-cols-7 gap-1 text-center">
    {initialDays.map((cell) =>
      cell.day === 0 ? (
        <div class="h-7" />
      ) : (
        <button
          type="button"
          data-date={cell.key}
          data-has-post={cell.hasPost ? 'true' : 'false'}
          class={`calendar-day h-7 w-7 mx-auto flex items-center justify-center rounded-full text-xs transition-colors
            ${cell.key === todayKey ? 'ring-1 ring-primary' : ''}
            ${cell.hasPost
              ? 'font-medium text-primary hover:bg-primary/10 cursor-pointer'
              : 'text-gray-500 dark:text-gray-400 cursor-default'}
          `}
        >
          {cell.day}
        </button>
      )
    )}
  </div>

  <div class="calendar-posts mt-4 hidden">
    <div class="text-xs font-medium text-gray-500 dark:text-gray-400 mb-2 calendar-posts-date" />
    <div class="space-y-2 calendar-posts-list" />
  </div>
</div>

<script>
  function initCalendars() {
    document.querySelectorAll('.calendar-widget').forEach((widget) => {
      if ((widget as HTMLElement).dataset.initialized) return;
      (widget as HTMLElement).dataset.initialized = 'true';

      const postsByDate: Record<string, { title: string; slug: string }[]> = JSON.parse(
        widget.getAttribute('data-posts') || '{}'
      );
      const yearMonths: string[] = JSON.parse(widget.getAttribute('data-year-months') || '[]');
      const locale = widget.getAttribute('data-locale') || 'zh-tw';
      let currentYear = Number(widget.getAttribute('data-init-year'));
      let currentMonth = Number(widget.getAttribute('data-init-month'));
      const todayKey = widget.getAttribute('data-today') || '';
      const routePrefix = widget.getAttribute('data-route-prefix') || '/post/';

      const monthNames =
        locale.startsWith('zh')
          ? [
              '1月', '2月', '3月', '4月', '5月', '6月',
              '7月', '8月', '9月', '10月', '11月', '12月',
            ]
          : [
              'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
              'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec',
            ];

      const labelEl = widget.querySelector('.calendar-month-label') as HTMLElement;
      const daysEl = widget.querySelector('.calendar-days') as HTMLElement;
      const prevBtn = widget.querySelector('.calendar-prev') as HTMLElement;
      const nextBtn = widget.querySelector('.calendar-next') as HTMLElement;
      const postsContainer = widget.querySelector('.calendar-posts') as HTMLElement;
      const postsDateEl = widget.querySelector('.calendar-posts-date') as HTMLElement;
      const postsListEl = widget.querySelector('.calendar-posts-list') as HTMLElement;

      function daysInMonth(year: number, month: number) {
        return new Date(year, month + 1, 0).getDate();
      }
      function firstDayOfMonth(year: number, month: number) {
        return new Date(year, month, 1).getDay();
      }
      function ymKey(year: number, month: number) {
        return `${year}-${String(month + 1).padStart(2, '0')}`;
      }

      function render() {
        if (labelEl) {
          labelEl.textContent = `${currentYear} ${monthNames[currentMonth]}`;
        }

        const totalDays = daysInMonth(currentYear, currentMonth);
        const firstDay = firstDayOfMonth(currentYear, currentMonth);
        let html = '';
        for (let i = 0; i < firstDay; i++) {
          html += '<div class="h-7"></div>';
        }
        for (let d = 1; d <= totalDays; d++) {
          const key = `${currentYear}-${String(currentMonth + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
          const hasPost = !!postsByDate[key];
          const isToday = key === todayKey;
          const ringClass = isToday ? 'ring-1 ring-primary' : '';
          const colorClass = hasPost
            ? 'font-medium text-primary hover:bg-primary/10 cursor-pointer'
            : 'text-gray-500 dark:text-gray-400 cursor-default';
          html += `<button type="button" data-date="${key}" data-has-post="${hasPost ? 'true' : 'false'}" class="calendar-day h-7 w-7 mx-auto flex items-center justify-center rounded-full text-xs transition-colors ${ringClass} ${colorClass}">${d}</button>`;
        }
        if (daysEl) daysEl.innerHTML = html;

        // Re-bind day clicks
        daysEl?.querySelectorAll('.calendar-day[data-has-post="true"]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const date = (btn as HTMLElement).getAttribute('data-date') || '';
            showPosts(date);
          });
        });
      }

      function showPosts(date: string) {
        const posts = postsByDate[date];
        if (!posts || posts.length === 0) {
          if (postsContainer) postsContainer.classList.add('hidden');
          return;
        }
        const [y, m, d] = date.split('-');
        const dateText = locale.startsWith('zh') ? `${y}年${m}月${d}日` : `${y}-${m}-${d}`;
        if (postsDateEl) postsDateEl.textContent = dateText;
        if (postsListEl) {
          postsListEl.innerHTML = posts
            .map(
              (p) =>
                `<a href="${routePrefix}${p.slug}" class="block text-xs text-gray-600 dark:text-gray-300 hover:text-primary transition-colors truncate">${p.title}</a>`
            )
            .join('');
        }
        if (postsContainer) postsContainer.classList.remove('hidden');
      }

      function goPrev() {
        currentMonth--;
        if (currentMonth < 0) {
          currentMonth = 11;
          currentYear--;
        }
        render();
      }

      function goNext() {
        currentMonth++;
        if (currentMonth > 11) {
          currentMonth = 0;
          currentYear++;
        }
        render();
      }

      prevBtn?.addEventListener('click', goPrev);
      nextBtn?.addEventListener('click', goNext);

      // Initial bind
      render();
    });
  }

  initCalendars();
  document.addEventListener('astro:after-swap', initCalendars);
</script>
