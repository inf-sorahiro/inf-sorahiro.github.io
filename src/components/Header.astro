---
import { SITE_TITLE } from '../consts';
import Search from './Search.astro';
import { useTranslations, getNavItems, getLocalePath, getAlternateLocalePath, type Locale } from '../i18n/utils';

const locale = Astro.currentLocale as Locale;
const t = useTranslations(locale);
const navItems = getNavItems(locale);

function isArticleLabel(item: typeof navItems[number]) {
  return item.label === t('nav.articles');
}
---

<header class="sticky top-0 z-50 backdrop-blur-md bg-white/80 dark:bg-[var(--color-bg-dark)]/80 border-b border-gray-200/50 dark:border-gray-700/50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={getLocalePath('/', locale)} class="flex items-center gap-2 shrink-0">
        <span class="text-xl font-bold text-primary hover:opacity-80 transition-opacity">
          {SITE_TITLE}
        </span>
      </a>

      <nav class="hidden md:flex items-center gap-1" aria-label="Navigation">
        {navItems.map((item) => (
          isArticleLabel(item) ? (
            <div class="relative group">
              <span class="px-3 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 group-hover:text-primary dark:group-hover:text-primary group-hover:bg-primary/5 transition-colors cursor-pointer flex items-center gap-1">
                {item.label}
                <svg class="w-3 h-3 opacity-50 group-hover:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
              <div class="absolute top-full left-0 mt-1 w-36 py-2 bg-white dark:bg-[var(--color-card-dark)] rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
                <a href={getLocalePath('/categories', locale)} class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  {t('nav.categories')}
                </a>
                <a href={getLocalePath('/tags', locale)} class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  {t('nav.tags')}
                </a>
                <a href={getLocalePath('/archives', locale)} class="block px-4 py-2 text-sm text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors">
                  {t('nav.archives')}
                </a>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="px-3 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 hover:text-primary dark:hover:text-primary hover:bg-primary/5 transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
      </nav>

      <div class="flex items-center gap-2">
        <button
          id="search-trigger"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label={t('search.title')}
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </button>

        <button
          id="theme-toggle"
          class="p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label={t('theme.toggle')}
        >
          <span id="theme-icon-auto" class="hidden">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none">
              <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M12 2a10 10 0 0 0 0 20V2z" fill="currentColor"/>
              <path d="M12 2v20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span id="theme-icon-light" class="hidden">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </span>
          <span id="theme-icon-dark" class="hidden">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
          </span>
        </button>

        <a
          href={getAlternateLocalePath(Astro.url.pathname, locale)}
          class="hidden md:flex p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm font-medium"
          aria-label={t('lang.switch')}
        >
          {t('lang.switch')}
        </a>

        <button
          id="mobile-menu-btn"
          class="md:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
          aria-label={t('menu.toggle')}
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <nav class="flex flex-col gap-1">
        {navItems.map((item) => (
          <div>
            <a
              href={isArticleLabel(item) ? undefined : item.href}
              class={`block px-3 py-2 text-sm font-medium rounded-lg text-gray-600 dark:text-gray-300 hover:text-primary hover:bg-primary/5 transition-colors ${isArticleLabel(item) ? 'cursor-pointer' : ''}`}
            >
              {item.label}
            </a>
            {isArticleLabel(item) && (
              <div class="ml-4 space-y-0">
                <a href={getLocalePath('/categories', locale)} class="block px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors">
                  {t('nav.categories')}
                </a>
                <a href={getLocalePath('/tags', locale)} class="block px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors">
                  {t('nav.tags')}
                </a>
                <a href={getLocalePath('/archives', locale)} class="block px-3 py-1.5 text-sm text-gray-500 dark:text-gray-400 hover:text-primary transition-colors">
                  {t('nav.archives')}
                </a>
              </div>
            )}
          </div>
        ))}
      </nav>
    </div>
  </div>
</header>

<Search />

<script is:inline>
  function updateThemeIcon() {
    var stored = localStorage.theme;
    var isAuto = !stored || stored === 'auto';
    var isDark = stored === 'dark';
    var isLight = stored === 'light';

    var autoEl = document.getElementById('theme-icon-auto');
    var lightEl = document.getElementById('theme-icon-light');
    var darkEl = document.getElementById('theme-icon-dark');

    if (autoEl) autoEl.classList.toggle('hidden', !isAuto);
    if (lightEl) lightEl.classList.toggle('hidden', !isLight);
    if (darkEl) darkEl.classList.toggle('hidden', !isDark);
  }

  function handleThemeToggle() {
    var stored = localStorage.theme;
    var next;
    if (stored === 'dark') next = 'light';
    else if (stored === 'light') next = 'auto';
    else next = 'dark';

    if (next === 'auto') {
      localStorage.removeItem('theme');
    } else {
      localStorage.theme = next;
    }

    var actual = window.__getTheme ? window.__getTheme() : (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    if (window.__applyTheme) {
      window.__applyTheme(actual);
    } else {
      document.documentElement.classList.toggle('dark', actual === 'dark');
    }

    updateThemeIcon();
  }

  function handleMobileMenu() {
    var menu = document.getElementById('mobile-menu');
    if (menu) {
      menu.classList.toggle('hidden');
    }
  }

  function bindHandlers() {
    var themeBtn = document.getElementById('theme-toggle');
    var mobileBtn = document.getElementById('mobile-menu-btn');

    if (themeBtn) {
      themeBtn.removeEventListener('click', handleThemeToggle);
      themeBtn.addEventListener('click', handleThemeToggle);
    }

    if (mobileBtn) {
      mobileBtn.removeEventListener('click', handleMobileMenu);
      mobileBtn.addEventListener('click', handleMobileMenu);
    }
  }

  bindHandlers();
  updateThemeIcon();

  document.addEventListener('astro:after-swap', function() {
    bindHandlers();
    updateThemeIcon();
  });
</script>
