---
import TagPage from '../../../components/pages/TagPage.astro';

export async function getStaticPaths() {
  const { getTagStaticPaths } = await import('../../../utils/i18n-content');
  return getTagStaticPaths('zh-tw');
}

const { tag } = Astro.params;
---

<TagPage locale={Astro.currentLocale} tag={tag!} />
