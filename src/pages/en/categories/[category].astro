---
import CategoryPage from '../../../components/pages/CategoryPage.astro';

export async function getStaticPaths() {
  const { getCategoryStaticPaths } = await import('../../../utils/i18n-content');
  return getCategoryStaticPaths('en');
}

const { category } = Astro.params;
---

<CategoryPage locale={Astro.currentLocale} category={category!} />